# GitLab
GITLAB_VERSION=18.11.1-ce.0
GITLAB_SERVER_IP=SERVER_IP
GITLAB_EXTERNAL_URL=http://SERVER_IP:14080
GITLAB_HTTP_PORT=14080
GITLAB_SSH_PORT=14022
GITLAB_HOME=/opt/data/gitlab
GITLAB_SHM_SIZE=512m

# PostgreSQL infra
POSTGRES_INFRA_VERSION=16-alpine
POSTGRES_INFRA_HOME=/opt/ai-dev-infra/data/postgres-infra
POSTGRES_INFRA_USER=postgres
POSTGRES_INFRA_PASSWORD=PASSWORD
POSTGRES_INFRA_DB=postgres

# Mattermost
MATTERMOST_VERSION=10.11.8
MATTERMOST_EXTERNAL_URL=http://SERVER_IP:18065
MATTERMOST_HTTP_PORT=18065
MATTERMOST_HOME=/opt/ai-dev-infra/data/mattermost
MATTERMOST_DB_NAME=mattermost
MATTERMOST_DB_USER=mattermost
MATTERMOST_DB_PASSWORD=PASSWORD
